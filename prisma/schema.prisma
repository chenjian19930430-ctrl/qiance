generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  code          String         @unique
  logo          String?
  status        Int            @default(0)
  expireAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  agents        Agent[]
  categories    Category[]
  companies     Company[]
  contracts     Contract[]
  conversations Conversation[]
  dashboards    Dashboard[]
  depts         Dept[]
  orders        Order[]
  posts         Post[]
  roles         Role[]
  shops         Shop[]
  skus          Sku[]
  spus          Spu[]
  suppliers     Supplier[]
  users         User[]
}

model User {
  id               String        @id @default(cuid())
  tenantId         String
  username         String        @unique
  password         String
  realName         String
  phone            String?
  email            String?
  avatar           String?
  status           Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  messages         ChatMessage[]
  createdCompanies Company[]     @relation("CompanyCreator")
  createdShops     Shop[]        @relation("ShopCreator")
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  depts            UserDept[]
  posts            UserPost[]
  roles            UserRole[]

  @@index([tenantId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  code        String           @unique
  sort        Int              @default(0)
  status      Int              @default(0)
  remark      String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  users       UserRole[]

  @@index([tenantId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Permission {
  id        String           @id @default(cuid())
  name      String
  code      String           @unique
  type      Int              @default(0)
  parentId  String?
  path      String?
  component String?
  icon      String?
  sort      Int              @default(0)
  visible   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  parent    Permission?      @relation("PermissionTree", fields: [parentId], references: [id])
  children  Permission[]     @relation("PermissionTree")
  roles     RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Dept {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  code      String
  parentId  String?
  sort      Int        @default(0)
  status    Int        @default(0)
  leader    String?
  phone     String?
  email     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Dept?      @relation("DeptTree", fields: [parentId], references: [id])
  children  Dept[]     @relation("DeptTree")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  users     UserDept[]

  @@index([tenantId])
}

model UserDept {
  userId String
  deptId String
  dept   Dept   @relation(fields: [deptId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, deptId])
}

model Post {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  code      String     @unique
  sort      Int        @default(0)
  status    Int        @default(0)
  remark    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  users     UserPost[]

  @@index([tenantId])
}

model UserPost {
  userId String
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Company {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  contact   String?
  status    Int      @default(0)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creatorId String?
  creator   User?    @relation("CompanyCreator", fields: [creatorId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  orders    Order[]
  shops     Shop[]
  spus      Spu[]

  @@index([tenantId])
}

model Shop {
  id           String         @id @default(cuid())
  tenantId     String
  companyId    String
  name         String
  code         String
  channel      String?
  url          String?
  status       Int            @default(0)
  remark       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  creatorId    String?
  orderItems   OrderItem[]
  company      Company        @relation(fields: [companyId], references: [id])
  creator      User?          @relation("ShopCreator", fields: [creatorId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  skus         Sku[]
  spus         Spu[]
  supplierShop SupplierShop[]

  @@index([tenantId])
  @@index([companyId])
}

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?
  sort      Int        @default(0)
  status    Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  spus      Spu[]

  @@index([tenantId])
}

model Spu {
  id          String    @id @default(cuid())
  tenantId    String
  companyId   String
  shopId      String?
  categoryId  String?
  name        String
  code        String
  brand       String?
  description String?
  status      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  skus        Sku[]
  category    Category? @relation(fields: [categoryId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id])
  shop        Shop?     @relation(fields: [shopId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@index([categoryId])
}

model Sku {
  id         String      @id @default(cuid())
  tenantId   String
  spuId      String
  shopId     String?
  name       String
  code       String
  salePrice  Decimal     @default(0) @db.Decimal(10, 2)
  costPrice  Decimal     @default(0) @db.Decimal(10, 2)
  stock      Int         @default(0)
  status     Int         @default(0)
  spec       Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  shop       Shop?       @relation(fields: [shopId], references: [id])
  spu        Spu         @relation(fields: [spuId], references: [id])
  tenant     Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([spuId])
  @@index([shopId])
}

model Order {
  id             String      @id @default(cuid())
  tenantId       String
  companyId      String
  orderNo        String      @unique
  type           Int         @default(0)
  channel        String?
  orderStatus    Int         @default(0)
  totalAmount    Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  realAmount     Decimal     @default(0) @db.Decimal(10, 2)
  platformFee    Decimal     @default(0) @db.Decimal(10, 2)
  logisticsFee   Decimal     @default(0) @db.Decimal(10, 2)
  buyerName      String?
  buyerPhone     String?
  buyerAddress   String?
  remark         String?
  orderTime      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  company        Company     @relation(fields: [companyId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  items          OrderItem[]

  @@index([tenantId])
  @@index([companyId])
  @@index([orderNo])
  @@index([type])
  @@index([orderTime])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  shopId    String?
  skuId     String?
  skuName   String
  quantity  Int      @default(1)
  unitPrice Decimal  @default(0) @db.Decimal(10, 2)
  subtotal  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop      Shop?    @relation(fields: [shopId], references: [id])
  sku       Sku?     @relation(fields: [skuId], references: [id])

  @@index([orderId])
  @@index([shopId])
  @@index([skuId])
}

model Conversation {
  id        String        @id @default(cuid())
  tenantId  String
  userId    String
  title     String        @default("新对话")
  agentId   String?
  status    Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  tenant    Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  agentId        String?
  tokens         Int?
  metadata       Json?
  createdAt      DateTime     @default(now())
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

model DouyinShop {
  id            String    @id @default(cuid())
  tenantId      String
  shopName      String
  shopId        String    @unique       // 抖店分配的店铺ID
  accessToken   String?                 // OAuth token
  refreshToken  String?
  tokenExpire   DateTime?
  authStatus    Int       @default(0)   // 0=未授权 1=已授权 2=已过期
  lastSyncTime  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Agent {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  code        String   @unique
  group       String
  description String?
  prompt      String
  icon        String?
  sort        Int      @default(0)
  status      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([code])
  @@index([group])
}

model Supplier {
  id        String         @id @default(cuid())
  tenantId  String
  name      String
  code      String
  contact   String?
  phone     String?
  address   String?
  status    Int            @default(0)
  remark    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  contracts    Contract[]
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  shops        SupplierShop[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model SupplierShop {
  supplierId String
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([supplierId, shopId])
}

model Contract {
  id         String    @id @default(cuid())
  tenantId   String
  supplierId String
  contractNo String    @unique
  name       String
  type       Int       @default(0)
  amount     Decimal   @default(0) @db.Decimal(12, 2)
  startDate  DateTime?
  endDate    DateTime?
  status     Int       @default(0)
  file       String?
  remark     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([supplierId])
}

model PurchaseOrder {
  id          String          @id @default(cuid())
  orderNo     String          @unique    // 采购单号：PO-YYYYMMDD-NNN
  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id])
  status      Int             @default(0) // 0=草稿 1=待审核 2=已确认 3=部分入库 4=已完成 5=已取消
  totalAmount Int             @default(0) // 采购总额（分）
  paidAmount  Int             @default(0)
  freight     Int             @default(0)
  remark      String?
  items       PurchaseOrderItem[]
  creator     String?                    // 创建人
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PurchaseOrderItem {
  id            String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  spuId         String?
  skuId         String?
  spuName       String?                 // 商品名称（快照）
  skuSpec       String?                 // SKU规格（快照）
  quantity      Int                     // 采购数量
  price         Int                     // 采购单价（分）
  receivedQty   Int         @default(0) // 已入库数量
  createdAt     DateTime    @default(now())
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  contact   String?
  phone     String?
  status    Int      @default(0)
  tenantId  String   @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stockItems StockItem[]
}

model StockItem {
  id          String   @id @default(cuid())
  spuId       String?
  skuId       String?
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  quantity    Int      @default(0)
  locked      Int      @default(0)      // 锁定库存（未发货订单占用）
  threshold   Int      @default(10)     // 库存预警阈值

  spuName     String?                   // 快照
  skuSpec     String?                   // 快照
  skuCode     String?
  unit        String   @default("个")
  tenantId    String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dashboard {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  name      String
  config    Json?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
}
