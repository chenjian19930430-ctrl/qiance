# ============================================================
# 千策（QianCe AI）— 生产部署配置
# ============================================================

# Database
DATABASE_URL="postgresql://postgres:password@postgres:5432/qiance?schema=public"

# Auth
AUTH_SECRET="qiance-auth-secret-prod-2026-change-this-in-production"
AUTH_URL="http://localhost:3000"

# AI Provider (Primary: OpenAI)
AI_PRIMARY_PROVIDER="openai"
AI_PRIMARY_MODEL="gpt-4o-mini"

# AI Fallback
AI_FALLBACK_PROVIDER="minimax"
AI_FALLBACK_MODEL="minimax-pro"

# API Keys — 务必替换为真实密钥
OPENAI_API_KEY="sk-your-openai-api-key"
MINIMAX_API_KEY="sk-your-minimax-api-key"

# WebSocket
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Server
NEXT_PUBLIC_APP_URL="http://localhost:3000"
